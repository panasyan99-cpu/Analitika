# НЕ заменяйте этим файлом существующие Streamlit Secrets.
# Скопируйте только блок [order_storage] и добавьте его в самый низ
# существующего TOML-документа в Streamlit Cloud → Settings → Secrets.

[order_storage]
endpoint_url = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
access_key_id = "<ACCESS_KEY_ID>"
secret_access_key = "<SECRET_ACCESS_KEY>"
bucket = "analitika-orders"
region = "auto"
prefix = "princess/analitika/supplier-orders"
required = true
